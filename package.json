{
  "name": "react-native-device-risk-signals",
  "version": "0.2.0",
  "description": "React Native device risk signals for root, jailbreak, emulator, tampering, Frida, VPN, and proxy detection",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "author": "AfanasievN (https://github.com/AfanasievN)",
  "license": "MIT",
  "homepage": "https://github.com/AfanasievN/react-native-device-risk-signals#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AfanasievN/react-native-device-risk-signals.git"
  },
  "bugs": {
    "url": "https://github.com/AfanasievN/react-native-device-risk-signals/issues"
  },
  "scripts": {
    "prebuild": "node scripts/clean.mjs",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --runInBand --watchman=false",
    "typecheck": "tsc --noEmit",
    "verify:contract": "node scripts/verify-native-contract.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "verify": "npm test && npm run typecheck && npm run verify:contract && npm run build && npm run verify:package",
    "benchmark:runner": "npm run build && node scripts/benchmark-probe-runner.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run verify",
    "example:start": "npm --prefix example run start",
    "example:android": "npm --prefix example run android",
    "example:ios": "npm --prefix example run ios",
    "example:test": "npm --prefix example run test"
  },
  "files": [
    "lib",
    "android/build.gradle",
    "android/src",
    "ios",
    "src",
    "!src/**/*.spec.ts",
    "RnDeviceIntel.podspec",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "react-native",
    "react-native-security",
    "mobile-security",
    "device-risk",
    "device-intelligence",
    "device-signals",
    "device-integrity",
    "risk-signals",
    "fraud-prevention",
    "root-detection",
    "jailbreak-detection",
    "emulator-detection",
    "frida-detection",
    "tamper-detection",
    "vpn-detection",
    "proxy-detection",
    "android-security",
    "ios-security",
    "turbomodule",
    "new-architecture"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.76"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/babel-preset": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "typescript": "^5.8.3"
  },
  "codegenConfig": {
    "name": "DeviceIntelSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.reactnativedeviceintel"
    }
  }
}
