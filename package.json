{
  "name": "react-native-device-risk-signals",
  "version": "1.0.0",
  "description": "Privacy-conscious device risk signal collection for React Native",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "author": "React Native Device Risk Signals contributors",
  "license": "MIT",
  "homepage": "https://github.com/OWNER/react-native-device-risk-signals",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OWNER/react-native-device-risk-signals.git"
  },
  "bugs": {
    "url": "https://github.com/OWNER/react-native-device-risk-signals/issues"
  },
  "scripts": {
    "test": "jest --runInBand --watchman=false",
    "typecheck": "tsc --noEmit",
    "example:start": "npm --prefix example run start",
    "example:android": "npm --prefix example run android",
    "example:ios": "npm --prefix example run ios",
    "example:test": "npm --prefix example run test"
  },
  "files": [
    "android/build.gradle",
    "android/src",
    "ios",
    "src",
    "!src/**/*.spec.ts",
    "RnDeviceIntel.podspec",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react-native",
    "device-risk",
    "device-integrity",
    "fraud-prevention",
    "turbomodule"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.71"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/babel-preset": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "typescript": "^5.8.3"
  },
  "codegenConfig": {
    "name": "DeviceIntelSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.reactnativedeviceintel"
    }
  }
}
