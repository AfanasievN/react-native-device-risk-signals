{
  "extends": "./tsconfig",
  "compilerOptions": {
    "composite": false,
    "rootDir": "./src",
    "outDir": "./lib",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "declaration": true,
    "noEmit": false
  },
  "include": ["./src/**/*", "./src/**/*.json"],
  "exclude": ["./src/**/*.spec.ts", "./src/**/*.spec.tsx"]
}
